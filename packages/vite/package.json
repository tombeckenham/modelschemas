{
  "name": "@modelschemas/vite",
  "version": "0.1.0",
  "description": "Vite plugin for modelschemas: pull selected JSON Schemas + generated TypeScript at dev time, verify offline at build time.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "!src/**/*.test.ts"
  ],
  "license": "MIT",
  "homepage": "https://modelschemas.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/modelschemas/modelschemas.git",
    "directory": "packages/vite"
  },
  "bugs": "https://github.com/modelschemas/modelschemas/issues",
  "keywords": [
    "vite-plugin",
    "ai",
    "json-schema",
    "codegen",
    "schemas"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelschemas/codegen": "workspace:*"
  },
  "peerDependencies": {
    "vite": ">=5"
  }
}
